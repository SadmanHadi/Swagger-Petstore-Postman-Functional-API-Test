{
  "info": {
    "_postman_id": "8ec7a915-4a11-4b2a-8c3b-3652c5c96f2a",
    "name": "Petstore API Functional Tests",
    "description": " Playwright API Functional API tests for Swagger Petstore.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Pet Operations",
      "item": [
        {
          "name": "Add Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "// Capture ID from raw response to avoid precision loss",
                  "const id = pm.response.text().match(/\"id\":\\s*(\\d+)/)[1];",
                  "pm.collectionVariables.set(\"pet_id\", id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pet_{{$timestamp}}\",\n  \"status\": \"available\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pet",
              "host": ["{{baseUrl}}"],
              "path": ["pet"]
            }
          }
        },
        {
          "name": "Add Pet - Boundary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}\",\n  \"status\": \"available\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pet",
              "host": ["{{baseUrl}}"],
              "path": ["pet"]
            }
          }
        },
        {
          "name": "Get Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pet/{{pet_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["pet", "{{pet_id}}"]
            }
          }
        },
        {
          "name": "Update Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{pet_id}},\n  \"status\": \"sold\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pet",
              "host": ["{{baseUrl}}"],
              "path": ["pet"]
            }
          }
        },
        {
          "name": "Cleanup Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Cleanup OK\", () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pet/{{pet_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["pet", "{{pet_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "User Operations",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set(\"user_name\", pm.request.body.raw.match(/\"username\":\\s*\"([^\"]+)\"/)[1]);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user_{{$timestamp}}\",\n  \"email\": \"test_{{$timestamp}}@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": ["{{baseUrl}}"],
              "path": ["user"]
            }
          }
        },
        {
          "name": "Delete User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"User deleted\", () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{user_name}}",
              "host": ["{{baseUrl}}"],
              "path": ["user", "{{user_name}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "pet_id", "value": "" },
    { "key": "user_name", "value": "" }
  ]
}
