{
  "info": {
    "_postman_id": "8ec7a915-4a11-4b2a-8c3b-3652c5c96f2a",
    "name": "Petstore API Functional Tests",
    "description": "Postman API Functional tests for Swagger Petstore.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Ensure a run-scoped timestamp for unique names (used by requests that need it)",
          "if (!pm.collectionVariables.get('run_ts')) {",
          "  pm.collectionVariables.set('run_ts', Date.now());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Pet Operations",
      "item": [
        {
          "name": "Add Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const schema = {",
                  "  \"type\": \"object\",",
                  "  \"required\": [\"id\", \"name\"],",
                  "  \"properties\": {",
                  "    \"id\": { \"type\": \"number\" },",
                  "    \"name\": { \"type\": \"string\" }",
                  "  }",
                  "};",
                  "pm.test(\"Schema is valid\", () => pm.response.to.have.jsonSchema(schema));",
                  "// Capture ID from raw response to avoid precision loss",
                  "const id = pm.response.text().match(/\"id\":\\s*(\\d+)/)[1];",
                  "pm.collectionVariables.set(\"pet_id\", id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pet_{{$timestamp}}\",\n  \"status\": \"available\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pet",
              "host": ["{{baseUrl}}"],
              "path": ["pet"]
            }
          }
        },
        {
          "name": "Add Pet - Boundary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Name matches request\", () => {",
                  "  const reqName = JSON.parse(pm.request.body.raw).name;",
                  "  pm.expect(pm.response.json().name).to.eql(reqName);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}\",\n  \"status\": \"available\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pet",
              "host": ["{{baseUrl}}"],
              "path": ["pet"]
            }
          }
        },
        {
          "name": "Add Pet - Negative (Empty Body)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 400, 405 or 415\", () => pm.expect(pm.response.code).to.be.oneOf([400, 405, 415]));",
                  "pm.test(\"Error handling present\", () => {",
                  "  const code = pm.response.code;",
                  "  pm.expect([400, 405, 415]).to.include(code);",
                  "  const text = pm.response.text();",
                  "  if (text && text.trim().startsWith('{')) {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body && (body.message !== undefined || body.code !== undefined)).to.be.true;",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pet",
              "host": ["{{baseUrl}}"],
              "path": ["pet"]
            }
          }
        },
        {
          "name": "Get Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const schema = {",
                  "  \"type\": \"object\",",
                  "  \"required\": [\"id\", \"name\", \"status\"],",
                  "  \"properties\": {",
                  "    \"id\": { \"type\": \"number\" },",
                  "    \"name\": { \"type\": \"string\" },",
                  "    \"status\": { \"type\": \"string\" }",
                  "  }",
                  "};",
                  "pm.test(\"Schema is valid\", () => pm.response.to.have.jsonSchema(schema));",
                  "pm.test(\"ID matches\", () => {",
                  "    const responseId = pm.response.text().match(/\"id\":\\s*(\\d+)/)[1];",
                  "    pm.expect(responseId).to.eql(pm.collectionVariables.get(\"pet_id\"));",
                  "  });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pet/{{pet_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["pet", "{{pet_id}}"]
            }
          }
        },
        {
          "name": "Update Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Status is sold\", () => pm.expect(pm.response.json().status).to.eql(\"sold\"));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{pet_id}},\n  \"status\": \"sold\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/pet",
              "host": ["{{baseUrl}}"],
              "path": ["pet"]
            }
          }
        },
        {
          "name": "Cleanup Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Cleanup OK\", () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pet/{{pet_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["pet", "{{pet_id}}"]
            }
          }
        },
        {
          "name": "Get Pet - Negative (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 404\", () => pm.response.to.have.status(404));",
                  "pm.test(\"Message is Pet not found\", () => pm.expect(pm.response.json().message).to.eql(\"Pet not found\"));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pet/999999999999999",
              "host": ["{{baseUrl}}"],
              "path": ["pet", "999999999999999"]
            }
          }
        }
      ]
    },
    {
      "name": "User Operations",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const reqUser = JSON.parse(pm.request.body.raw).username;",
                  "pm.collectionVariables.set(\"user_name\", reqUser);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user_{{$timestamp}}\",\n  \"email\": \"test_{{$timestamp}}@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": ["{{baseUrl}}"],
              "path": ["user"]
            }
          }
        },
        {
          "name": "Delete User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"User deleted\", () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/{{user_name}}",
              "host": ["{{baseUrl}}"],
              "path": ["user", "{{user_name}}"]
            }
          }
        },
        {
          "name": "Get User - Negative (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 404\", () => pm.response.to.have.status(404));",
                  "pm.test(\"Message is User not found\", () => pm.expect(pm.response.json().message).to.eql(\"User not found\"));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/nonexist_{{$timestamp}}",
              "host": ["{{baseUrl}}"],
              "path": ["user", "nonexist_{{$timestamp}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "pet_id", "value": "" },
    { "key": "user_name", "value": "" }
  ]
}
